# Example .pypirc for Artifactory
# Copy this to ~/.pypirc and fill in your credentials
#
# IMPORTANT: Never commit credentials to version control!
# This file should be in your home directory, NOT in the repo.

[distutils]
index-servers =
    artifactory

[artifactory]
repository = https://your-artifactory-url.govcloud.amazonaws.com/artifactory/api/pypi/pypi-local
username = your-username
password = your-api-token

# Usage:
# twine upload --repository artifactory dist/*
#
# Or set environment variables instead:
# export ARTIFACTORY_URL=https://your-artifactory-url.govcloud.amazonaws.com/artifactory
# export ARTIFACTORY_REPO=pypi-local
# export ARTIFACTORY_USER=your-username
# export ARTIFACTORY_TOKEN=your-api-token
#
# Then use:
# make publish
